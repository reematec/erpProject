<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
        Form View: Updated to support multi-size sampling and 
        lifecycle status tracking (Draft -> In Progress -> Completed -> Shipped).
    -->
    <record id="view_reema_sampling_blueprint_form" model="ir.ui.view">
        <field name="name">reema.sampling.blueprint.form</field>
        <field name="model">reema.sampling.blueprint</field>
        <field name="arch" type="xml">
            <form>
                <!-- Header: Contains buttons and the status bar -->
                <header>
                    <button name="action_start"
                            string="Start"
                            type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_sample_approved"
                            string="Mark Sample Approved"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'in_progress'"/>
                    <button name="action_production_ready"
                            string="Mark Production Ready"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'sample_approved'"/>
                    <button name="action_completed"
                            string="Complete"
                            type="object"
                            invisible="state != 'production_ready'"/>
                    <button name="action_shipped"
                            string="Ship"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'completed'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ('cancelled', 'shipped')"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <button name="action_print_sampling" string="Print" type="object"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,sample_approved,production_ready,completed,shipped"/>
                </header>
                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bom"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list">
                            <field name="bom_count" widget="statinfo" string="BoM"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="reference" readonly="1"/>
                        </h1>
                        <label for="name" string="Sample Name"/>
                        <h2>
                            <field name="name" placeholder="e.g. World Cup 2026 Pro"/>
                        </h2>
                    </div>
                    
                    <!-- Main Information Group -->
                    <group>
                        <group string="Basic Details">
                            <field name="model_alias"/>
                            <field name="customer_id"/>
                            <field name="sampling_date"/>
                        </group>
                        <group string="Status &amp; Tracking">
                            <field name="completion_date"/>
                            <field name="shipping_date"/>
                            <field name="reference_piece_kept"/>
                        </group>
                    </group>

                    <group>
                        <group string="Design Specification">
                            <field name="ball_type"/>
                            <field name="construction_type"/>
                            <field name="total_panels" readonly="1"/>
                            <field name="color"/>
                        </group>
                        <group string="Technical Requirements">
                            <field name="weight_range"/>
                            <field name="circumference"/>
                            <field name="bounce_requirement"/>
                        </group>
                    </group>

                    <!-- File Uploads Section (Moved before Size Details as requested) -->
                    <group string="Attachments &amp; Layouts">
                        <group>
                            <label for="layout_file" string="Layout Image/PDF"/>
                            <div class="o_row">
                                <field name="layout_file" filename="layout_filename"/>
                                <field name="layout_filename" invisible="1"/>
                            </div>
                        </group>
                        <group>
                            <field name="final_sample_images" widget="many2many_binary" string="Final Sample Images"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Size &amp; Production Quantities" name="sizes">
                            <field name="size_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="ball_size"/>
                                    <field name="cutting_knife_no"/>
                                    <field name="qty_to_produce" string="Quantity"/>
                                </list>
                            </field>
                        </page>
                        <page string="Material Information" name="materials">
                            <!-- 
                                Material Lines: 'options' are used here to disable 'create' and 'edit',
                                ensuring users only select existing materials from the catalog.
                            -->
                            <field name="material_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" 
                                           domain="[('type', '=', 'consu')]" 
                                           string="Material"
                                           options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                                    <field name="description"/>
                                    <field name="notes" string="Notes"/>
                                </list>
                            </field>
                        </page>
                        <!-- Cutting Knives Tab -->
                        <page string="Cutting Knives" name="cutting_knives">
                            <field name="knife_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="shape_name"/>
                                    <field name="panel_count"/>
                                </list>
                            </field>
                            <group>
                                <field name="total_panels" readonly="1"/>
                            </group>
                        </page>
                        <!-- General Notes Tab -->
                        <page string="General Notes" name="general_notes">
                            <field name="notes" placeholder="Add any additional requirements..."/>
                        </page>
                    </notebook>
                </sheet>
                <!-- 
                    Chatter: This section enables the activity log, messaging, and followers 
                    on the right side (or bottom) of the form. 
                -->
                <chatter>
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_reema_sampling_blueprint_tree" model="ir.ui.view">
        <field name="name">reema.sampling.blueprint.list</field>
        <field name="model">reema.sampling.blueprint</field>
        <field name="arch" type="xml">
            <list>
                <!-- Layout Preview added to the list view for easy identification -->
                <field name="layout_file" widget="image" options="{'size': [40, 40]}" string="Layout"/>
                <field name="reference"/>
                <field name="name"/>
                <field name="model_alias"/>
                <field name="customer_id"/>
                <field name="sampling_date"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'completed'"/>
            </list>
        </field>
    </record>

    <!-- 
        Kanban View: Acts as a dashboard for the sampling department. 
        It organizes records into columns based on their 'state'.
    -->
    <record id="view_reema_sampling_blueprint_kanban" model="ir.ui.view">
        <field name="name">reema.sampling.blueprint.kanban</field>
        <field name="model">reema.sampling.blueprint</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" quick_create="false">
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click shadow-sm border-0">
                            <div class="o_kanban_image" t-if="record.layout_file.raw_value">
                                <field name="layout_file" widget="image"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="reference"/> - <field name="name"/>
                                </strong>
                                <div class="text-muted">
                                    <field name="customer_id"/>
                                </div>
                                <div class="mt-2">
                                    <span>Date: <field name="sampling_date"/></span>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="construction_type"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_reema_sampling_blueprint" model="ir.actions.act_window">
        <field name="name">Sampling Overview</field>
        <field name="res_model">reema.sampling.blueprint</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sample!
            </p>
        </field>
    </record>

    <menuitem id="menu_reema_sampling_root"
              name="Sampling"
              sequence="10"/>

    <menuitem id="menu_reema_sampling_blueprint" 
              name="Samples" 
              parent="menu_reema_sampling_root" 
              action="action_reema_sampling_blueprint" 
              sequence="10"/>
</odoo>
