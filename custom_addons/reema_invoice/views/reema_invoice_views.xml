<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════════
         LIST VIEW  —  overview of all Pro Forma Invoices
    ════════════════════════════════════════════════════════════════════════ -->
    <record id="view_reema_invoice_list" model="ir.ui.view">
        <field name="name">reema.invoice.list</field>
        <field name="model">reema.invoice</field>
        <field name="arch" type="xml">
            <list string="Pro Forma Invoices" decoration-info="state == 'pending'"
                  decoration-success="state == 'accepted'" decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="client_order_number"/>
                <field name="shipping_date"/>
                <field name="total_qty"/>
                <field name="total_amount" widget="monetary"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-warning="state == 'sent'"
                       decoration-success="state == 'accepted'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         FORM VIEW
    ════════════════════════════════════════════════════════════════════════ -->
    <record id="view_reema_invoice_form" model="ir.ui.view">
        <field name="name">reema.invoice.form</field>
        <field name="model">reema.invoice</field>
        <field name="arch" type="xml">
            <form string="Pro Forma Invoice">

                <header>
                    <button name="action_sent"           string="Mark as Sent" type="object"
                            class="oe_highlight" invisible="state != 'pending'"/>
                    <button name="action_accept"         string="Accept"       type="object"
                            class="oe_highlight" invisible="state != 'sent'"/>
                    <button name="action_reject"         string="Reject"       type="object"
                            invisible="state != 'sent'"/>
                    <button name="action_close"          string="Close"        type="object"
                            invisible="state not in ('accepted', 'rejected')"/>
                    <button name="action_reset_to_pending" string="Reset to Pending" type="object"
                            invisible="state == 'pending'"/>
                    <button name="action_print_invoice"  string="Print PI"     type="object"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,sent,accepted,rejected"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!--
                        Main section: Customer Details (left) + Shipping and Terms (right).
                        ALL required fields from the task are visible here — no hidden tabs.
                    -->
                    <group>
                        <group string="Customer Details">
                            <field name="partner_id"
                                   options="{'no_create': True, 'no_edit': True}"/>
                            <field name="client_address"/>
                            <field name="date"/>
                            <field name="client_order_number"/>
                            <field name="client_order_date"/>
                            <field name="payment_terms_id"/>
                        </group>
                        <group string="Shipping and Terms">
                            <field name="our_address"/>
                            <field name="country_of_origin"/>
                            <field name="transport_method"/>
                            <field name="shipping_date"/>
                            <field name="incoterm_id"/>
                            <field name="incoterm_location"/>
                            <field name="destination"/>
                        </group>
                    </group>

                    <notebook>

                        <!-- ── Products / Samples tab ───────────────────────────────── -->
                        <page string="Products / Samples" name="products">
                            <field name="line_ids">
                                <!--
                                    This is a plain custom model — "Add a Section", "Add a Note",
                                    and "Catalog" buttons will NOT appear (they only exist on
                                    account.move.line which has display_type / product catalog support).
                                    There are also NO taxes fields in this model by design.
                                -->
                                <list editable="bottom" no_open="True">
                                    <field name="sample_id"    options="{'no_create': True}"/>
                                    <field name="sample_name"  string="Name"/>
                                    <field name="client_sku"   string="Client SKU"/>
                                    <field name="size_id"      options="{'no_create': True}"/>
                                    <field name="sample_color" string="Color"/>
                                    <field name="hs_code"      string="HS Code"/>
                                    <field name="ean"          string="EAN"/>
                                    <field name="qty"          string="Qty"/>
                                    <field name="price_unit"   string="Unit Price"/>
                                    <field name="price_subtotal" string="Amount"/>
                                </list>
                            </field>

                            <!-- Totals block — no taxes row -->
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_qty"/>
                                <field name="total_amount" widget="monetary"/>
                                <field name="handling_charges" widget="monetary"/>
                                <field name="courier_charges"  widget="monetary"/>
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                    <label for="net_total_payable"/>
                                </div>
                                <field name="net_total_payable" nolabel="1"
                                       class="oe_subtotal_footer_separator" widget="monetary"/>
                            </group>
                        </page>

                        <!-- ── Bank Details tab ─────────────────────────────────────── -->
                        <page string="Bank Details" name="bank_details">
                            <group>
                                <group>
                                    <field name="bank_name"/>
                                    <field name="bank_title"/>
                                    <field name="bank_address"/>
                                </group>
                                <group>
                                    <field name="account_num"/>
                                    <field name="iban"/>
                                    <field name="swift"/>
                                </group>
                            </group>
                        </page>

                    </notebook>
                </sheet>

                <chatter>
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>

            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ACTION  —  opens the list/form views
    ════════════════════════════════════════════════════════════════════════ -->
    <record id="action_reema_invoice" model="ir.actions.act_window">
        <field name="name">Pro Forma Invoices</field>
        <field name="res_model">reema.invoice</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Pro Forma Invoice!
            </p>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MENUS
    ════════════════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_reema_invoice_root"
              name="Pro Forma Invoices"
              sequence="25"/>

    <menuitem id="menu_reema_invoice_all"
              name="All Invoices"
              parent="menu_reema_invoice_root"
              action="action_reema_invoice"
              sequence="10"/>

</odoo>
