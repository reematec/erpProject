<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form View ──────────────────────────────────────────────────── -->
    <record id="view_reema_purchase_order_form" model="ir.ui.view">
        <field name="name">reema.purchase.order.form</field>
        <field name="model">reema.purchase.order</field>
        <field name="arch" type="xml">
            <form string="Purchase Order">
                <header>
                    <button name="action_submit" string="Submit for Confirmation"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Submit this Purchase Order for Production Manager confirmation?"/>
                    <button name="action_confirm" string="Confirm PO"
                            type="object" class="btn-primary"
                            groups="reema_purchase.group_reema_purchase_manager"
                            invisible="state != 'submitted'"
                            confirm="Confirm this Purchase Order?"/>
                    <button name="action_approve" string="Approve PO"
                            type="object" class="btn-success"
                            groups="reema_purchase.group_reema_owner"
                            invisible="state != 'confirmed' or not needs_approval"
                            confirm="Approve this Purchase Order? It will become active."/>
                    <button name="action_print_po" string="Print / PDF"
                            type="object" class="btn-secondary"/>
                    <button name="action_cancel" string="Cancel PO"
                            type="object" class="btn-danger"
                            invisible="state in ('cancelled', 'approved')"
                            confirm="Are you sure you want to cancel this Purchase Order? This cannot be undone if GRNs exist."/>
                    <button name="action_reset_to_draft" string="Reset to Draft"
                            type="object"
                            groups="reema_purchase.group_reema_purchase_manager"
                            invisible="state not in ('submitted', 'confirmed')"
                            confirm="Reset this PO back to Draft?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,confirmed,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_gate_passes" type="object"
                                class="oe_stat_button" icon="fa-truck"
                                invisible="gate_pass_count == 0">
                            <field name="gate_pass_count" widget="statinfo" string="Inward Gate Passes"/>
                        </button>
                        <button name="action_view_grns" type="object"
                                class="oe_stat_button" icon="fa-clipboard-check"
                                invisible="grn_count == 0">
                            <field name="grn_count" widget="statinfo" string="GRNs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Approval notice -->
                    <div class="alert alert-info" role="alert"
                         invisible="not needs_approval or state not in ('confirmed',)">
                        <strong>Waiting Owner Approval:</strong> This PO contains products that require
                        Owner/Admin final approval before it becomes active.
                    </div>
                    <div class="alert alert-success" role="alert"
                         invisible="needs_approval or state not in ('confirmed',)">
                        <strong>Active:</strong> No owner approval required — this PO is confirmed and active.
                    </div>

                    <group>
                        <group string="Supplier">
                            <field name="partner_id"
                                   domain="[('supplier_rank', '>', 0), ('is_contractor', '=', False)]"
                                   options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                                   readonly="state not in ('draft', 'submitted')"/>
                            <field name="partner_ref"
                                   readonly="state not in ('draft', 'submitted')"/>
                            <field name="payment_term_id"
                                   options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                                   readonly="state not in ('draft', 'submitted')"/>
                        </group>
                        <group string="Order Info">
                            <field name="date" readonly="state not in ('draft', 'submitted')"/>
                            <field name="date_expected" readonly="state not in ('draft', 'submitted')"/>
                            <field name="buyer_id"
                                   options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                                   readonly="1"/>
                            <field name="currency_id"
                                   options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                                   readonly="1"/>
                            <field name="needs_approval" readonly="1"
                                   groups="reema_purchase.group_reema_purchase_manager"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Order Lines" name="order_lines">
                            <field name="line_ids" readonly="state not in ('draft', 'submitted')">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"
                                           options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                                           domain="[('product_tmpl_id.product_group', '=', 'raw_material')]"
                                           required="1"/>
                                    <field name="name"/>
                                    <field name="product_qty"/>
                                    <field name="product_uom_id"
                                           options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                                    <field name="price_unit"/>
                                    <field name="color"/>
                                    <field name="thickness"/>
                                    <field name="tax_ids" widget="many2many_tags"
                                           options="{'no_create': True, 'no_edit': True}"/>
                                    <field name="price_subtotal" readonly="1"/>
                                    <field name="qty_received" readonly="1" optional="show"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_untaxed" readonly="1"/>
                                <field name="amount_tax" readonly="1"/>
                                <field name="amount_total" readonly="1" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Terms &amp; Notes" name="notes">
                            <field name="notes" placeholder="Internal terms, conditions, or notes..."
                                   readonly="state not in ('draft', 'submitted')"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── List View ──────────────────────────────────────────────────── -->
    <record id="view_reema_purchase_order_list" model="ir.ui.view">
        <field name="name">reema.purchase.order.list</field>
        <field name="model">reema.purchase.order</field>
        <field name="arch" type="xml">
            <list string="Purchase Orders" decoration-info="state == 'draft'"
                  decoration-warning="state == 'submitted'"
                  decoration-success="state in ('confirmed', 'approved')"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id" domain="[('supplier_rank', '>', 0), ('is_contractor', '=', False)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                <field name="product_summary" readonly="1"/>
                <field name="date_expected" optional="show"/>
                <field name="buyer_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" optional="hide"/>
                <field name="amount_total" optional="hide"/>
                <field name="needs_approval" widget="boolean" optional="show"
                       groups="reema_purchase.group_reema_purchase_manager"/>
                <field name="grn_count" string="GRNs" optional="hide"/>
                <field name="state" widget="badge" optional="show"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state in ('confirmed', 'approved')"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ── Search View ────────────────────────────────────────────────── -->
    <record id="view_reema_purchase_order_search" model="ir.ui.view">
        <field name="name">reema.purchase.order.search</field>
        <field name="model">reema.purchase.order</field>
        <field name="arch" type="xml">
            <search string="Search Purchase Orders">
                <field name="name" string="PO Number"/>
                <field name="partner_id" domain="[('supplier_rank', '>', 0), ('is_contractor', '=', False)]"/>
                <field name="buyer_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Waiting Confirmation" name="submitted" domain="[('state','=','submitted')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Needs Owner Approval" name="needs_approval"
                        domain="[('needs_approval','=',True),('state','=','confirmed')]"
                        groups="reema_purchase.group_reema_owner"/>
                <separator/>
                <filter string="Cancelled" name="cancelled" domain="[('state','=','cancelled')]"/>
                <group expand="0" string="Group By">
                    <filter string="Supplier" name="by_supplier" context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="by_state" context="{'group_by': 'state'}"/>
                    <filter string="Month" name="by_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────── -->
    <record id="action_reema_purchase_order" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="res_model">reema.purchase.order</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_reema_purchase_order_search"/>
        <field name="context">{}</field>
    </record>

</odoo>
