<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cleanup: remove orphaned Piece Rate Matrix records left in DB after file deletion -->
    <delete model="ir.ui.menu" search="[('name', '=', 'Piece Rate Matrix')]"/>
    <delete model="ir.actions.act_window" search="[('name', '=', 'Piece Rate Matrix')]"/>

    <!-- Contractors: action + menu under Manufacturing > Configuration -->
    <record id="action_reema_contractors" model="ir.actions.act_window">
        <field name="name">Contractors</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('supplier_rank', '>', 0)]</field>
        <field name="context">{'default_supplier_rank': 1, 'default_is_contractor': True}</field>
    </record>
    <menuitem
        id="reema_mrp_menu_contractors"
        name="Contractors"
        parent="mrp.menu_mrp_configuration"
        action="action_reema_contractors"
        sequence="25"
        groups="reema_mrp.group_reema_production_manager,base.group_erp_manager"/>

    <!-- Extend Manufacturing Order Form -->
    <record id="mrp_production_reema_form" model="ir.ui.view">
        <field name="name">mrp.production.reema.form</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <!-- Smart button: Material Issuances -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_issuances"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-archive">
                    <field name="issuance_count" widget="statinfo" string="Issuances"/>
                </button>
            </xpath>
            <!-- Authorize/View issuance buttons — separate columns with headers -->
            <xpath expr="//field[@name='move_raw_ids']//list" position="inside">
                <field name="has_issuance" column_invisible="1"/>
                <button name="action_authorize_issuance"
                        type="object"
                        string="Authorize"
                        icon="fa-arrow-circle-right"
                        title="Click to authorize issuance for this component"
                        invisible="has_issuance or state == 'cancel'"/>
                <button name="action_view_issuance"
                        type="object"
                        string="View Auth"
                        icon="fa-eye"
                        title="Authorization already exists — click to view"
                        invisible="not has_issuance or state == 'cancel'"/>
            </xpath>
            <!-- Make quantity (done) readonly and relabel to Consumed -->
            <xpath expr="//field[@name='move_raw_ids']//field[@name='quantity']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="string">Consumed</attribute>
            </xpath>
            <!-- Hide picked (Consumed checkbox) — consumption tracked via RMI, not MO form -->
            <xpath expr="//field[@name='move_raw_ids']//field[@name='picked']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='bom_id']" position="after">
                <field name="construction_type" options="{'no_create': True, 'no_edit': True}"
                       readonly="state != 'draft'"/>
                <field name="ball_size" options="{'no_create': True, 'no_edit': True}"
                       readonly="state != 'draft'"/>
                <field name="complexity_level" options="{'no_create': True, 'no_edit': True}"
                       readonly="state != 'draft'"/>
            </xpath>
            <!-- Responsible becomes readonly once MO is confirmed -->
            <xpath expr="//field[@name='user_id'][@widget='many2one_avatar']" position="attributes">
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>
            <!-- qty_producing is tracked through work order batch entries — make it readonly -->
            <xpath expr="//field[@name='qty_producing']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <!-- Reservation is handled via physical RMI issuance, not Odoo stock reservation -->
            <xpath expr="//button[@name='action_assign']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='do_unreserve']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Produce/Produce All, Plan, Start are redundant — tracked via work order batch entries -->
            <xpath expr="//button[@name='button_mark_done']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='button_plan']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_start']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Move Cancel to the very end and rename to "Cancel MO" so it's not confused with browser back -->
            <xpath expr="//header/button[@name='action_cancel']" position="replace"/>
            <xpath expr="//header/button[@name='button_unbuild']" position="after">
                <button name="action_cancel" type="object" string="Cancel MO"
                        data-hotkey="x"
                        invisible="not id or state in ('done', 'cancel')"
                        confirm="Are you sure you want to cancel this Manufacturing Order? This cannot be undone."
                        confirm-label="Yes, Cancel MO"
                        cancel-label="Go Back"/>
            </xpath>
        </field>
    </record>

    <!-- Extend Work Order List -->
    <record id="mrp_workorder_reema_list" model="ir.ui.view">
        <field name="name">mrp.workorder.reema.list</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_tree_editable_view_mo_form"/>
        <field name="arch" type="xml">
            <!-- Insert custom columns after product_id so product stays right after work center -->
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="workforce_type" column_invisible="1"/>
                <field name="contractor_ids" widget="many2many_tags" options="{'no_create': True, 'no_edit': True}"
                       invisible="workforce_type == 'employee'"/>
                <field name="hall_qty" string="Target" readonly="1"/>
                <field name="qty_batch_completed" string="Completed" readonly="1"/>
                <field name="qty_balls_completed" string="Balls Done" readonly="1" optional="show"/>
                <button name="action_log_batch" type="object"
                        icon="fa-plus-circle"
                        title="Log batch progress"
                        groups="reema_mrp.group_reema_supervisor"
                        invisible="state != 'progress'"/>
            </xpath>
            <!-- Hide the "Open Work Order" external-link icon added by the MO form view -->
            <xpath expr="//button[@name='action_open_wizard']" position="replace"/>
            <!-- Hide Pause — redundant in batch logging flow -->
            <xpath expr="//button[@name='button_pending']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <!-- Operation name is set from the BOM — floor operators must not rename it -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <!-- Work center is defined in the BOM and must not change after MO creation -->
            <xpath expr="//field[@name='workcenter_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <!-- Disable delete — work orders are managed at BOM level, not removed mid-production -->
            <xpath expr="//list" position="attributes">
                <attribute name="delete">0</attribute>
            </xpath>
            <!-- Hide qty columns — hall_qty (Target) is the only qty operators need -->
            <xpath expr="//field[@name='qty_remaining']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='qty_produced']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <!-- Hide expected and real duration — not relevant for floor operators -->
            <xpath expr="//field[@name='duration_expected']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='duration']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
        </field>
    </record>

    <!-- BOM Form: add reference number, hide Catalog shortcut and Product Attachment column -->
    <record id="mrp_bom_reema_form" model="ir.ui.view">
        <field name="name">mrp.bom.reema.form</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <!-- Show BOM reference as a title above the fields -->
            <xpath expr="//sheet/group[1]" position="before">
                <div class="oe_title">
                    <h1><field name="reema_reference" readonly="1"/></h1>
                </div>
                <!-- Lock warning: shown when a confirmed MO is using this BOM -->
                <div class="alert alert-warning mb-3" role="alert"
                     invisible="not has_active_mo">
                    <field name="has_active_mo" invisible="1"/>
                    <strong>BOM Locked.</strong>
                    A Manufacturing Order exists for this BOM.
                    Cancel the MO before making any changes.
                </div>
            </xpath>
            <!-- Lock product and qty fields when BOM has active MOs -->
            <xpath expr="//field[@name='product_tmpl_id']" position="attributes">
                <attribute name="readonly">has_active_mo</attribute>
            </xpath>
            <xpath expr="//field[@name='product_qty']" position="attributes">
                <attribute name="readonly">has_active_mo</attribute>
            </xpath>
            <!-- Remove "Catalog" button from component add-line controls -->
            <xpath expr="//field[@name='bom_line_ids']//control/button[@name='action_add_from_catalog']" position="replace"/>
            <!-- Hide Product Attachment button and count from component lines -->
            <xpath expr="//field[@name='bom_line_ids']//button[@name='action_see_attachments']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='bom_line_ids']//field[@name='attachments_count']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <!-- Hide Odoo's built-in free-text Reference (code) field — replaced by reema_reference -->
            <xpath expr="//field[@name='code']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <!-- Hide the operation dependencies toggle — always on by default, no user action needed -->
            <xpath expr="//page[@name='miscellaneous']//field[@name='allow_operation_dependencies']"
                   position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
        </field>
    </record>

    <!-- BOM List: show reema_reference as first column -->
    <record id="mrp_bom_reema_list" model="ir.ui.view">
        <field name="name">mrp.bom.reema.list</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[1]" position="before">
                <field name="reema_reference" string="BOM Ref"/>
            </xpath>
        </field>
    </record>

    <!-- BOM Operations list: replace the Archive button with a Delete button that shows a confirm dialog.
         Odoo sets delete="0" and puts an Archive button — we swap that for a proper delete with warning.
         Also make the list inline-editable so balls_per_unit can be set without opening a popup. -->
    <record id="mrp_routing_workcenter_bom_reema" model="ir.ui.view">
        <field name="name">mrp.routing.workcenter.bom.reema</field>
        <field name="model">mrp.routing.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_routing_workcenter_bom_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="editable">bottom</attribute>
            </xpath>
            <xpath expr="//button[@name='action_archive']" position="replace">
                <button name="action_delete_operation"
                        type="object"
                        icon="fa-trash"
                        title="Delete this operation"
                        confirm="Are you sure you want to permanently delete this operation? This cannot be undone."
                        invisible="context.get('parent_production_id')"/>
            </xpath>
            <xpath expr="//field[@name='workcenter_id']" position="after">
                <field name="balls_per_unit"/>
                <field name="piece_rate_id" options="{'no_create': True, 'no_edit': True}"
                       domain="[('workcenter_id', '=', workcenter_id)]"/>
            </xpath>
            <!-- Hide Duration Computation and Duration columns — not relevant for floor ops -->
            <xpath expr="//field[@name='time_mode']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='time_cycle']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <!-- Show Blocked By column by default (remove optional hide + always visible) -->
            <xpath expr="//field[@name='blocked_by_operation_ids']" position="attributes">
                <attribute name="optional">show</attribute>
                <attribute name="column_invisible">0</attribute>
            </xpath>
        </field>
    </record>

    <!-- BOM Operations popup form: add balls_per_unit and piece_rate_id so they're editable when opening a row -->
    <record id="mrp_routing_workcenter_form_reema" model="ir.ui.view">
        <field name="name">mrp.routing.workcenter.form.reema</field>
        <field name="model">mrp.routing.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_routing_workcenter_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='workcenter_id']" position="after">
                <field name="balls_per_unit"/>
                <field name="piece_rate_id" options="{'no_create': True, 'no_edit': True}"
                       domain="[('workcenter_id', '=', workcenter_id)]"/>
            </xpath>
        </field>
    </record>

    <!-- Extend WorkCenter Form: SFG product and hall location -->
    <record id="mrp_workcenter_reema_form" model="ir.ui.view">
        <field name="name">mrp.workcenter.reema.form</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='capacity']" position="inside">
                <field name="workforce_type"/>
                <field name="expense_account_id"
                       options="{'no_create': True, 'no_edit': True}"
                       invisible="workforce_type == 'employee'"/>
                <field name="is_qc_point"/>
                <field name="sfg_product_id"
                       domain="[('product_group', '=', 'sfg')]"
                       options="{'no_create': True, 'no_edit': True}"/>
                <field name="location_id"
                       domain="[('usage', '=', 'internal')]"
                       options="{'no_create': True, 'no_edit': True}"/>
            </xpath>
            <xpath expr="//label[@for='time_efficiency']" position="replace"/>
            <xpath expr="//div[field[@name='time_efficiency']]" position="replace"/>
            <xpath expr="//label[@for='oee_target']" position="replace"/>
            <xpath expr="//div[field[@name='oee_target']]" position="replace"/>
            <xpath expr="//label[@for='time_start']" position="replace"/>
            <xpath expr="//div[field[@name='time_start']]" position="replace"/>
            <xpath expr="//label[@for='time_stop']" position="replace"/>
            <xpath expr="//div[field[@name='time_stop']]" position="replace"/>
            <xpath expr="//field[@name='alternative_workcenter_ids']" position="replace"/>
            <xpath expr="//field[@name='resource_calendar_id']" position="replace"/>
            <xpath expr="//field[@name='default_capacity']" position="replace"/>
            <xpath expr="//group[@name='costing']" position="replace"/>
            <xpath expr="//page[@name='capacity']" position="replace"/>
        </field>
    </record>

    <!-- Product Form: add Product Group after Product Type; move Category to follow it -->
    <record id="product_template_reema_form" model="ir.ui.view">
        <field name="name">product.template.reema.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field name="product_group"/>
                <field name="categ_id" string="Category"/>
            </xpath>
            <xpath expr="//group[@name='group_standard_price']//field[@name='categ_id']" position="replace"/>
        </field>
    </record>

    <!-- Product List: add Product Group column and filter -->
    <record id="product_template_reema_list" model="ir.ui.view">
        <field name="name">product.template.reema.list</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="product_group" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Default product views to list instead of kanban -->
    <record id="product.product_template_action_all" model="ir.actions.act_window">
        <field name="view_mode">list,kanban,form,activity</field>
    </record>
    <record id="stock.product_template_action_product" model="ir.actions.act_window">
        <field name="view_mode">list,kanban,form,activity</field>
    </record>
    <record id="mrp.product_template_action" model="ir.actions.act_window">
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- Product Search: add Product Group filter and groupby -->
    <record id="product_template_reema_search" model="ir.ui.view">
        <field name="name">product.template.reema.search</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="before">
                <filter string="Raw Materials"  name="group_raw"      domain="[('product_group','=','raw_material')]"/>
                <filter string="Packaging"      name="group_pkg"      domain="[('product_group','=','packaging')]"/>
                <filter string="Semi-Finished"  name="group_sfg"      domain="[('product_group','=','sfg')]"/>
                <filter string="Finished Goods" name="group_fg"       domain="[('product_group','=','finished_good')]"/>
                <separator/>
            </xpath>
            <xpath expr="//filter[@name='inactive']" position="before">
                <filter string="Product Group" name="groupby_product_group"
                        context="{'group_by': 'product_group'}"/>
            </xpath>
        </field>
    </record>
</odoo>
