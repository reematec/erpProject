<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="reema_consumable_transaction_search" model="ir.ui.view">
        <field name="name">reema.consumable.transaction.search</field>
        <field name="model">reema.consumable.transaction</field>
        <field name="arch" type="xml">
            <search string="Consumable Store">
                <field name="product_id"/>
                <field name="name" string="Reference"/>
                <filter name="not_draft" string="Active"
                        domain="[('state', '!=', 'draft')]"/>
                <separator/>
                <filter name="issuances" string="Issuances"
                        domain="[('transaction_type', '=', 'issuance')]"/>
                <filter name="returns" string="Returns"
                        domain="[('transaction_type', '=', 'return')]"/>
                <group expand="0" string="Group By">
                    <filter name="by_product" string="Product"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="by_date" string="Date"
                            context="{'group_by': 'date:day'}"/>
                    <filter name="by_type" string="Type"
                            context="{'group_by': 'transaction_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Issuance Form -->
    <record id="reema_consumable_issuance_view_form" model="ir.ui.view">
        <field name="name">reema.consumable.issuance.form</field>
        <field name="model">reema.consumable.transaction</field>
        <field name="arch" type="xml">
            <form string="Consumable Issuance">
                <header>
                    <button name="action_process"
                            string="Process"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_void"
                            string="Void Issuance"
                            type="object"
                            groups="mrp.group_mrp_manager"
                            invisible="state != 'done'"
                            confirm="This will reverse the full stock move and void this record. Only proceed if no material has been physically returned. Continue?"
                            confirm-label="Yes, Void It"
                            cancel-label="Go Back"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,done,voided"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="New"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Item">
                            <field name="product_id"
                                   options="{'no_open': True}"
                                   readonly="state != 'draft'"/>
                            <field name="product_uom_id" options="{'no_open': True}"/>
                            <field name="qty" readonly="state != 'draft'"/>
                        </group>
                        <group string="Issue Details">
                            <field name="location_id"
                                   string="Issued To (Hall)"
                                   options="{'no_open': True}"
                                   readonly="state != 'draft'"/>
                            <field name="contractor_id"
                                   options="{'no_open': True}"
                                   readonly="state != 'draft'"/>
                            <field name="carried_by" readonly="state != 'draft'"/>
                            <field name="notes"
                                   placeholder="Optional: shift, batch, remarks"
                                   readonly="state != 'draft'"/>
                            <field name="processed_by" options="{'no_open': True}"/>
                            <field name="date"/>
                            <field name="move_id" optional="hide"/>
                        </group>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Return Form -->
    <record id="reema_consumable_return_view_form" model="ir.ui.view">
        <field name="name">reema.consumable.return.form</field>
        <field name="model">reema.consumable.transaction</field>
        <field name="arch" type="xml">
            <form string="Consumable Return">
                <header>
                    <button name="action_process"
                            string="Process"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="New"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Item">
                            <field name="product_id"
                                   options="{'no_open': True}"
                                   readonly="state != 'draft'"/>
                            <field name="product_uom_id" options="{'no_open': True}"/>
                            <field name="qty" readonly="state != 'draft'"/>
                        </group>
                        <group string="Return Details">
                            <field name="location_id"
                                   string="Returning From (Hall)"
                                   options="{'no_open': True}"
                                   readonly="state != 'draft'"/>
                            <field name="reason"
                                   placeholder="e.g. Excess, Wrong item, Unused"
                                   readonly="state != 'draft'"/>
                            <field name="notes"
                                   placeholder="Optional: shift, batch, remarks"
                                   readonly="state != 'draft'"/>
                            <field name="processed_by" options="{'no_open': True}"/>
                            <field name="date"/>
                            <field name="move_id" optional="hide"/>
                        </group>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="reema_consumable_transaction_view_list" model="ir.ui.view">
        <field name="name">reema.consumable.transaction.list</field>
        <field name="model">reema.consumable.transaction</field>
        <field name="arch" type="xml">
            <list create="0">
                <header>
                    <button name="action_new_issuance" string="New Issuance"
                            type="object" display="always" class="btn-primary"/>
                    <button name="action_new_return" string="New Return"
                            type="object" display="always"/>
                </header>
                <field name="name"/>
                <field name="date"/>
                <field name="transaction_type" widget="badge"
                       decoration-info="transaction_type == 'issuance'"
                       decoration-warning="transaction_type == 'return'"/>
                <field name="product_id"/>
                <field name="qty"/>
                <field name="product_uom_id" string="UOM"/>
                <field name="location_id" string="Hall"/>
                <field name="contractor_id" string="Issued To" optional="show"/>
                <field name="processed_by" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'voided'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Window Action -->
    <record id="reema_consumable_transaction_action" model="ir.actions.act_window">
        <field name="name">Consumable Store</field>
        <field name="res_model">reema.consumable.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="reema_consumable_transaction_search"/>
        <field name="context">{'search_default_not_draft': 1}</field>
    </record>

    <!-- Menu -->
    <menuitem id="reema_mrp_menu_consumable_store_inventory"
              name="Consumable Store"
              parent="reema_mrp_menu_issuances_root"
              action="reema_consumable_transaction_action"
              groups="base.group_user"
              sequence="2"/>
</odoo>
