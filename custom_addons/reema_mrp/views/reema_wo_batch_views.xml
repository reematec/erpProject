<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Log Batch Progress wizard -->
    <record id="view_reema_batch_entry_wizard_form" model="ir.ui.view">
        <field name="name">reema.batch.entry.wizard.form</field>
        <field name="model">reema.batch.entry.wizard</field>
        <field name="arch" type="xml">
            <form string="Log Batch Progress">
                <group>
                    <group string="Work Order">
                        <field name="workorder_id" readonly="1"/>
                        <field name="workcenter_name" readonly="1"/>
                        <field name="workcenter_id" invisible="1"/>
                    </group>
                    <group string="Progress">
                        <field name="hall_qty" string="Target" readonly="1"/>
                        <field name="qty_batch_completed" readonly="1"/>
                    </group>
                </group>
                <group>
                    <field name="workforce_type" invisible="1"/>
                    <field name="available_contractor_ids" invisible="1"/>
                    <field name="contractor_id" options="{'no_create': True, 'no_edit': True}"
                           invisible="workforce_type == 'employee'"
                           required="workforce_type != 'employee'"/>
                    <field name="qty" autofocus="1"/>
                    <field name="piece_rate_id" options="{'no_create': True, 'no_edit': True}"
                           invisible="workforce_type == 'employee'"/>
                    <field name="notes" placeholder="Optional: e.g. 'Morning shift batch'"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Save" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Standalone list view for all batch entries -->
    <record id="reema_batch_entry_view_list" model="ir.ui.view">
        <field name="name">reema.wo.batch.entry.list</field>
        <field name="model">reema.wo.batch.entry</field>
        <field name="arch" type="xml">
            <list string="Batch Logs" default_order="date desc" create="0" delete="0">
                <header>
                    <button name="action_create_contractor_bill" type="object"
                            string="Create Contractor Bill" class="btn-primary"
                            confirm="Create a vendor bill for the selected unbilled batch entries? All entries must belong to the same contractor."/>
                </header>
                <field name="name" string="Reference" readonly="1"/>
                <field name="date" string="Date"/>
                <field name="logged_by" string="Logged By"/>
                <field name="contractor_id" string="Contractor"/>
                <field name="reema_po_id" string="PO"/>
                <field name="mo_id" string="MO"/>
                <field name="process_name" string="Process"/>
                <field name="qty" string="Qty"/>
                <field name="qty_balls" string="Balls"/>
                <field name="piece_rate_value" string="Rate"/>
                <field name="amount_earned" string="Amount" sum="Total"/>
                <field name="is_billed" string="Billed" widget="boolean_toggle" readonly="1"/>
                <field name="bill_id" string="Bill Ref" optional="show"
                       context="{'form_view_ref': 'reema_accounting.view_contractor_bill_form'}"/>
                <field name="notes" string="Notes" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form view for batch entry (read-only detail) -->
    <record id="reema_batch_entry_view_form" model="ir.ui.view">
        <field name="name">reema.wo.batch.entry.form</field>
        <field name="model">reema.wo.batch.entry</field>
        <field name="arch" type="xml">
            <form string="Batch Log" create="false">
                <sheet>
                    <field name="workforce_type" invisible="1"/>
                    <group>
                        <group string="Work Order">
                            <field name="workorder_id" readonly="1"/>
                            <field name="date" readonly="1"/>
                            <field name="logged_by" readonly="1"/>
                        </group>
                        <group string="Contractor" invisible="workforce_type == 'employee'">
                            <field name="contractor_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Quantity">
                            <field name="qty" readonly="1"/>
                            <field name="qty_balls" readonly="1"/>
                        </group>
                        <group string="Piece Rate" invisible="workforce_type == 'employee'">
                            <field name="piece_rate_id" readonly="1"/>
                            <field name="amount_earned" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" readonly="1"/>
                    </group>
                    <group invisible="not is_billed">
                        <field name="bill_id" readonly="1"
                               context="{'form_view_ref': 'reema_accounting.view_contractor_bill_form'}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="reema_batch_entry_view_search" model="ir.ui.view">
        <field name="name">reema.wo.batch.entry.search</field>
        <field name="model">reema.wo.batch.entry</field>
        <field name="arch" type="xml">
            <search string="Batch Logs">
                <field name="logged_by" string="Logged By"/>
                <field name="contractor_id" string="Contractor"/>
                <field name="workorder_id" string="Work Order"/>
                <field name="piece_rate_id" string="Piece Rate"/>
                <filter string="Unbilled" name="unbilled" domain="[('is_billed', '=', False)]"/>
                <filter string="Billed"   name="billed"   domain="[('is_billed', '=', True)]"/>
                <separator/>
                <filter string="Today" name="today"
                        domain="[('date', '>=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>
                <filter string="This Month" name="this_month"
                        domain="[('date', '>=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Logged By" name="group_logged_by" context="{'group_by': 'logged_by'}"/>
                    <filter string="Contractor" name="group_contractor" context="{'group_by': 'contractor_id'}"/>
                    <filter string="Work Order" name="group_wo" context="{'group_by': 'workorder_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window action — Unbilled is the default filter -->
    <record id="reema_batch_entry_action" model="ir.actions.act_window">
        <field name="name">Batch Logs</field>
        <field name="res_model">reema.wo.batch.entry</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="reema_batch_entry_view_search"/>
        <field name="context">{'search_default_unbilled': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No batch entries found.
            </p>
        </field>
    </record>

    <menuitem id="reema_batch_entry_menu"
              name="Batch Logs"
              parent="mrp.menu_mrp_manufacturing"
              action="reema_batch_entry_action"
              sequence="25"/>

    <!-- Server action: Create Contractor Bill (kept for data integrity; button is in list header) -->
    <record id="action_create_contractor_bill_server" model="ir.actions.server">
        <field name="name">Create Contractor Bill</field>
        <field name="model_id" ref="reema_mrp.model_reema_wo_batch_entry"/>
        <field name="state">code</field>
        <field name="code">action = records.action_create_contractor_bill()</field>
    </record>

    <!-- Smart button on res.partner form -->
    <record id="res_partner_reema_batch_form" model="ir.ui.view">
        <field name="name">res.partner.reema.batch.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_batch_entries"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-list-ul"
                        invisible="batch_entry_count == 0">
                    <field name="batch_entry_count" widget="statinfo" string="Batch Logs"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
