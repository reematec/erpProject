<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Authorization Form -->
    <record id="reema_material_issuance_view_form" model="ir.ui.view">
        <field name="name">reema.material.issuance.form</field>
        <field name="model">reema.material.issuance</field>
        <field name="arch" type="xml">
            <form string="Material Issuance Authorization">
                <header>
                    <button name="action_issue_wizard"
                            string="Issue Materials"
                            type="object"
                            class="oe_highlight"
                            invisible="state not in ('authorized', 'partial')"/>
                    <button name="action_return_wizard"
                            string="Return Materials"
                            type="object"
                            invisible="state not in ('partial', 'fully_issued')"/>
                    <button name="action_print"
                            string="Print Slip"
                            type="object"
                            invisible="state == 'cancelled'"/>
                    <button name="action_cancel"
                            string="Withdraw Authorization"
                            type="object"
                            groups="mrp.group_mrp_manager"
                            invisible="state in ('fully_issued', 'cancelled') or has_any_issue"
                            confirm="Are you sure you want to withdraw this authorization? No further material can be issued against it."
                            confirm-label="Yes, Withdraw It"
                            cancel-label="Go Back"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="authorized,partial,fully_issued"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Authorized Material">
                            <field name="production_id" readonly="1"
                                   options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                            <field name="product_id" readonly="1"
                                   options="{'no_open': True}"/>
                            <field name="product_uom_id" readonly="1"
                                   options="{'no_open': True}"/>
                            <field name="authorized_qty" readonly="1"/>
                        </group>
                        <group string="Issue Status">
                            <field name="total_issued_qty" readonly="1"/>
                            <field name="total_returned_qty" readonly="1"/>
                            <field name="net_issued_qty" readonly="1"/>
                            <field name="remaining_qty" readonly="1"/>
                            <field name="authorized_by" readonly="1"
                                   options="{'no_open': True}"/>
                            <field name="date_authorized" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Issue History" name="issue_history">
                            <field name="line_ids">
                                <list create="0" delete="0" editable="bottom"
                                      decoration-muted="is_reversal">
                                    <field name="is_reversal" column_invisible="1"/>
                                    <field name="date" readonly="1"/>
                                    <field name="issued_qty" readonly="1"/>
                                    <field name="product_uom_id" string="UOM" readonly="1"/>
                                    <field name="destination_location_id" readonly="1"/>
                                    <field name="contractor_id" readonly="1"/>
                                    <field name="carried_by" readonly="1"/>
                                    <field name="issued_by" readonly="1"/>
                                    <field name="notes" optional="show" readonly="1"/>
                                    <field name="move_id" optional="hide" readonly="1"/>
                                    <button name="action_reverse_issue_line"
                                            type="object"
                                            icon="fa-undo"
                                            title="Reverse this entry"
                                            confirm="This will reverse the stock move and add a counter-entry. The action will be recorded in the chatter. Continue?"
                                            invisible="is_reversal or not id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Return History" name="return_history">
                            <field name="return_line_ids">
                                <list create="0" delete="0" editable="bottom"
                                      decoration-muted="is_reversal">
                                    <field name="is_reversal" column_invisible="1"/>
                                    <field name="date" readonly="1"/>
                                    <field name="returned_qty" readonly="1"/>
                                    <field name="product_uom_id" string="UOM" readonly="1"/>
                                    <field name="return_from_location_id" readonly="1"/>
                                    <field name="fault_description" readonly="1"/>
                                    <field name="returned_by" readonly="1"/>
                                    <field name="notes" optional="show" readonly="1"/>
                                    <field name="move_id" optional="hide" readonly="1"/>
                                    <button name="action_reverse_return_line"
                                            type="object"
                                            icon="fa-undo"
                                            title="Reverse this return entry"
                                            confirm="This will reverse the stock move and add a counter-entry. The action will be recorded in the chatter. Continue?"
                                            invisible="is_reversal or not id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="reema_material_issuance_view_list" model="ir.ui.view">
        <field name="name">reema.material.issuance.list</field>
        <field name="model">reema.material.issuance</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="production_id"/>
                <field name="product_id"/>
                <field name="authorized_qty"/>
                <field name="product_uom_id" string="UOM"/>
                <field name="total_issued_qty"/>
                <field name="total_returned_qty" optional="show"/>
                <field name="net_issued_qty" optional="show"/>
                <field name="remaining_qty"/>
                <field name="authorized_by" optional="show"/>
                <field name="date_authorized"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'authorized'"
                       decoration-warning="state == 'partial'"
                       decoration-success="state == 'fully_issued'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Issue Wizard Form -->
    <record id="reema_material_issue_wizard_view_form" model="ir.ui.view">
        <field name="name">reema.material.issue.wizard.form</field>
        <field name="model">reema.material.issue.wizard</field>
        <field name="arch" type="xml">
            <form string="Issue Materials">
                <group string="Authorized Material (cannot be changed)">
                    <field name="product_id" readonly="1"/>
                    <field name="product_uom_id" readonly="1" string="UOM"/>
                    <field name="authorized_qty" readonly="1"/>
                    <field name="remaining_qty" readonly="1"/>
                </group>
                <group string="Issuance Details">
                    <field name="issued_qty" autofocus="1"/>
                    <field name="destination_location_id"
                           options="{'no_create': True, 'no_edit': True}"/>
                    <field name="available_contractor_ids" invisible="1"/>
                    <field name="contractor_id"
                           options="{'no_create': True, 'no_edit': True}"/>
                    <field name="carried_by"
                           placeholder="Defaults to contractor name — change if assistant is collecting"/>
                    <field name="notes" placeholder="Optional: batch number, shift, remarks"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Issue" type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Return Wizard Form -->
    <record id="reema_material_return_wizard_view_form" model="ir.ui.view">
        <field name="name">reema.material.return.wizard.form</field>
        <field name="model">reema.material.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Return Materials">
                <group string="Material (cannot be changed)">
                    <field name="product_id" readonly="1"/>
                    <field name="product_uom_id" readonly="1" string="UOM"/>
                    <field name="total_issued_qty" readonly="1"/>
                    <field name="total_returned_qty" readonly="1"/>
                    <field name="returnable_qty" readonly="1"/>
                </group>
                <group string="Return Details">
                    <field name="returned_qty" autofocus="1"/>
                    <field name="return_from_location_id"
                           options="{'no_create': True, 'no_edit': True}"/>
                    <field name="fault_description"
                           placeholder="e.g. Color variation, Thickness inconsistency, Excess — not needed"/>
                    <field name="notes" placeholder="Optional: roll number, shift, remarks"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm Return" type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="reema_material_issuance_action" model="ir.actions.act_window">
        <field name="name">Material Issuances</field>
        <field name="res_model">reema.material.issuance</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Parent menu under Inventory -->
    <menuitem id="reema_mrp_menu_issuances_root"
              name="Store Issuances"
              parent="stock.menu_stock_root"
              groups="base.group_user"
              sequence="25"/>

    <!-- Raw Material Issuances (MO-linked) -->
    <menuitem id="reema_mrp_menu_issuances_inventory"
              name="Raw Material Issuances"
              parent="reema_mrp_menu_issuances_root"
              action="reema_material_issuance_action"
              groups="base.group_user"
              sequence="1"/>

    <!-- ═══════════════════════════════════════════════════════════
         MO Authorization Overview — store keeper entry point
         Shows one row per MO with pending material authorizations.
    ════════════════════════════════════════════════════════════ -->

    <!-- List view: one row per MO -->
    <record id="reema_mo_issuance_overview_list" model="ir.ui.view">
        <field name="name">mrp.production.issuance.overview.list</field>
        <field name="model">mrp.production</field>
        <field name="arch" type="xml">
            <list string="MO Authorizations" create="0" delete="0"
                  decoration-warning="pending_issuance_count &gt; 0">
                <field name="name" string="MO"/>
                <field name="product_id" string="Product"/>
                <field name="ball_size" string="Size"/>
                <field name="construction_type" string="Type"/>
                <field name="issuance_count" string="Total Auth"/>
                <field name="pending_issuance_count" string="Pending"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'confirmed'"
                       decoration-warning="state == 'progress'"
                       decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <!-- Form view: MO header + inline issuance list for store keeper -->
    <record id="reema_mo_issuance_overview_form" model="ir.ui.view">
        <field name="name">mrp.production.issuance.overview.form</field>
        <field name="model">mrp.production</field>
        <field name="arch" type="xml">
            <form string="Material Authorizations" create="false" edit="false">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="confirmed,progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Manufacturing Order">
                            <field name="product_id" readonly="1"/>
                            <field name="ball_size" readonly="1"/>
                            <field name="construction_type" readonly="1"/>
                        </group>
                        <group string="Issuance Summary">
                            <field name="issuance_count" readonly="1" string="Total Authorized"/>
                            <field name="pending_issuance_count" readonly="1" string="Pending Issue"/>
                        </group>
                    </group>
                    <field name="issuance_ids" readonly="1">
                        <list string="Component Authorizations" create="0" delete="0"
                              decoration-warning="state in ('authorized', 'partial')"
                              decoration-success="state == 'fully_issued'"
                              decoration-muted="state == 'cancelled'">
                            <field name="name" string="Reference"/>
                            <field name="product_id" string="Component"/>
                            <field name="authorized_qty" string="Auth Qty"/>
                            <field name="product_uom_id" string="UOM"/>
                            <field name="total_issued_qty" string="Issued"/>
                            <field name="remaining_qty" string="Remaining"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'authorized'"
                                   decoration-warning="state == 'partial'"
                                   decoration-success="state == 'fully_issued'"
                                   decoration-danger="state == 'cancelled'"
                                   string="Status"/>
                            <button name="action_open_issuance"
                                    type="object"
                                    icon="fa-arrow-right"
                                    title="Open to Issue / Return Materials"
                                    invisible="state == 'cancelled'"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view for MO overview (with Pending default filter) -->
    <record id="reema_mo_issuance_overview_search" model="ir.ui.view">
        <field name="name">mrp.production.issuance.overview.search</field>
        <field name="model">mrp.production</field>
        <field name="arch" type="xml">
            <search string="MO Authorizations">
                <field name="name" string="MO"/>
                <field name="product_id" string="Product"/>
                <filter string="Pending Issue" name="pending"
                        domain="[('pending_issuance_count', '&gt;', 0)]"/>
                <filter string="All" name="all" domain="[]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window action for MO overview -->
    <record id="reema_mo_issuance_overview_action" model="ir.actions.act_window">
        <field name="name">MO Authorizations</field>
        <field name="res_model">mrp.production</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('issuance_count', '&gt;', 0), ('state', 'not in', ['draft', 'done', 'cancel'])]</field>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="search_view_id" ref="reema_mo_issuance_overview_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('reema_mo_issuance_overview_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('reema_mo_issuance_overview_form')})]"/>
    </record>

    <!-- Menu: MO Authorizations — first item under Store Issuances -->
    <menuitem id="reema_mrp_menu_mo_authorizations"
              name="MO Authorizations"
              parent="reema_mrp_menu_issuances_root"
              action="reema_mo_issuance_overview_action"
              groups="base.group_user"
              sequence="0"/>

    <!-- Report action -->
    <record id="action_report_material_issuance" model="ir.actions.report">
        <field name="name">Material Issuance Slip</field>
        <field name="model">reema.material.issuance</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">reema_mrp.report_material_issuance_slip</field>
        <field name="report_file">reema_mrp.report_material_issuance_slip</field>
        <field name="print_report_name">'Issuance Slip - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_reema_material_issuance"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
