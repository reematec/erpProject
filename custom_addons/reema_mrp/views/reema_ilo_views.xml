<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════
         ILO PIECE RATES
    ═══════════════════════════════════════════════ -->

    <record id="view_reema_ilo_piece_rate_list" model="ir.ui.view">
        <field name="name">reema.ilo.piece.rate.list</field>
        <field name="model">reema.ilo.piece.rate</field>
        <field name="arch" type="xml">
            <list string="ILO Piece Rates" editable="bottom">
                <field name="contractor_id" options="{'no_create': True, 'no_edit': True}"/>
                <field name="construction_type"/>
                <field name="ball_size"/>
                <field name="rate" string="Rate (PKR)"/>
                <field name="bladder_deduction" string="No-Bladder Deduction (PKR)"/>
            </list>
        </field>
    </record>

    <record id="action_reema_ilo_piece_rate" model="ir.actions.act_window">
        <field name="name">ILO Piece Rates</field>
        <field name="res_model">reema.ilo.piece.rate</field>
        <field name="view_mode">list</field>
    </record>

    <!-- ═══════════════════════════════════════════════
         ILO DISPATCH
    ═══════════════════════════════════════════════ -->

    <record id="view_reema_ilo_dispatch_form" model="ir.ui.view">
        <field name="name">reema.ilo.dispatch.form</field>
        <field name="model">reema.ilo.dispatch</field>
        <field name="arch" type="xml">
            <form string="ILO Dispatch">
                <header>
                    <button name="action_dispatch" string="Dispatch" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Confirm dispatch? This will move panels to the ILO location."/>
                    <button name="action_close" string="Close" type="object"
                            invisible="state != 'dispatched'"
                            confirm="Close this dispatch? All balls must have been received."/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,dispatched,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Dispatch Info">
                            <field name="mo_id" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="contractor_id" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="ball_size" readonly="state != 'draft'"/>
                            <field name="construction_type" readonly="state != 'draft'"/>
                        </group>
                        <group string="Quantities Sent">
                            <field name="qty_panels" readonly="state != 'draft'"/>
                            <field name="qty_bladders" readonly="state != 'draft'"/>
                            <field name="qty_thread" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group>
                        <group string="Verification">
                            <field name="dispatched_by" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="verified_by" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="Return Status">
                            <field name="qty_returned"/>
                            <field name="qty_pending"/>
                        </group>
                    </group>
                    <field name="notes" readonly="state != 'draft'" placeholder="Any notes about this dispatch..."/>
                    <notebook>
                        <page string="Receipts" name="receipts">
                            <field name="receipt_ids" readonly="state == 'closed'">
                                <list string="Receipts">
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="qty_full"/>
                                    <field name="qty_no_bladder"/>
                                    <field name="qty_damaged"/>
                                    <field name="amount_due" string="Amount Due (PKR)"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_reema_ilo_dispatch_list" model="ir.ui.view">
        <field name="name">reema.ilo.dispatch.list</field>
        <field name="model">reema.ilo.dispatch</field>
        <field name="arch" type="xml">
            <list string="ILO Dispatches" decoration-warning="qty_pending > 0 and state == 'dispatched'"
                  decoration-success="state == 'closed'">
                <field name="name"/>
                <field name="date"/>
                <field name="mo_id"/>
                <field name="contractor_id"/>
                <field name="ball_size"/>
                <field name="construction_type"/>
                <field name="qty_panels"/>
                <field name="qty_returned"/>
                <field name="qty_pending"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'dispatched'"
                       decoration-success="state == 'closed'"/>
            </list>
        </field>
    </record>

    <record id="view_reema_ilo_dispatch_search" model="ir.ui.view">
        <field name="name">reema.ilo.dispatch.search</field>
        <field name="model">reema.ilo.dispatch</field>
        <field name="arch" type="xml">
            <search string="ILO Dispatches">
                <field name="name"/>
                <field name="mo_id"/>
                <field name="contractor_id"/>
                <filter name="pending" string="Pending" domain="[('qty_pending', '>', 0), ('state', '=', 'dispatched')]"/>
                <filter name="dispatched" string="Dispatched" domain="[('state', '=', 'dispatched')]"/>
                <filter name="closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_contractor" string="Contractor" context="{'group_by': 'contractor_id'}"/>
                    <filter name="group_mo" string="Manufacturing Order" context="{'group_by': 'mo_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_reema_ilo_dispatch" model="ir.actions.act_window">
        <field name="name">ILO Dispatches</field>
        <field name="res_model">reema.ilo.dispatch</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_reema_ilo_dispatch_search"/>
    </record>

    <record id="action_reema_ilo_pending" model="ir.actions.act_window">
        <field name="name">ILO Pending</field>
        <field name="res_model">reema.ilo.dispatch</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('qty_pending', '&gt;', 0), ('state', '=', 'dispatched')]</field>
        <field name="search_view_id" ref="view_reema_ilo_dispatch_search"/>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

    <!-- ═══════════════════════════════════════════════
         ILO RECEIPT
    ═══════════════════════════════════════════════ -->

    <record id="view_reema_ilo_receipt_form" model="ir.ui.view">
        <field name="name">reema.ilo.receipt.form</field>
        <field name="model">reema.ilo.receipt</field>
        <field name="arch" type="xml">
            <form string="ILO Receipt">
                <header>
                    <button name="action_receive" string="Confirm Receipt" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Confirm this receipt? The returned quantity will be recorded against the dispatch."/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,received"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Linked To">
                            <field name="dispatch_id" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="contractor_id"/>
                            <field name="mo_id"/>
                            <field name="ball_size"/>
                            <field name="construction_type"/>
                        </group>
                        <group string="Receipt Info">
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="received_by" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="verified_by" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Returned Quantities">
                        <group>
                            <field name="qty_full" readonly="state != 'draft'"/>
                            <field name="qty_no_bladder" readonly="state != 'draft'"/>
                            <field name="qty_damaged" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Payment Calculation">
                        <group>
                            <field name="piece_rate_id"
                                   options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="rate_full" readonly="state != 'draft'"/>
                            <field name="deduction_type" readonly="state != 'draft'"/>
                            <field name="deduction_per_ball"
                                   readonly="state != 'draft' or deduction_type == 'fixed'"/>
                        </group>
                        <group>
                            <field name="amount_full"/>
                            <field name="amount_no_bladder"/>
                            <field name="repair_deduction"/>
                            <field name="amount_due" class="fw-bold"/>
                        </group>
                    </group>
                    <field name="notes" readonly="state != 'draft'" placeholder="Any notes about this receipt..."/>
                    <notebook>
                        <page string="QC Repair Charges" name="repair_charges">
                            <div class="alert alert-info py-2 mb-2" role="alert" style="font-size:0.85rem">
                                <i class="fa fa-info-circle me-1"/>
                                QC repair charges are recorded by QC staff after initial quality inspection.
                                Each entry deducts from the contractor's amount due.
                            </div>
                            <field name="repair_charge_ids">
                                <list editable="bottom" string="Repair Charges">
                                    <field name="date"/>
                                    <field name="recorded_by" options="{'no_create': True, 'no_edit': True}"/>
                                    <field name="qty_failed"/>
                                    <field name="repair_charge_per_ball"/>
                                    <field name="total_deduction"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_reema_ilo_receipt_list" model="ir.ui.view">
        <field name="name">reema.ilo.receipt.list</field>
        <field name="model">reema.ilo.receipt</field>
        <field name="arch" type="xml">
            <list string="ILO Receipts">
                <field name="name"/>
                <field name="date"/>
                <field name="dispatch_id"/>
                <field name="contractor_id"/>
                <field name="qty_full"/>
                <field name="qty_no_bladder"/>
                <field name="qty_damaged"/>
                <field name="repair_deduction"/>
                <field name="amount_due" string="Amount Due (PKR)"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-success="state == 'received'"/>
            </list>
        </field>
    </record>

    <record id="view_reema_ilo_receipt_search" model="ir.ui.view">
        <field name="name">reema.ilo.receipt.search</field>
        <field name="model">reema.ilo.receipt</field>
        <field name="arch" type="xml">
            <search string="ILO Receipts">
                <field name="name"/>
                <field name="dispatch_id"/>
                <field name="contractor_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="received" string="Received" domain="[('state', '=', 'received')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_contractor" string="Contractor" context="{'group_by': 'contractor_id'}"/>
                    <filter name="group_mo" string="Manufacturing Order" context="{'group_by': 'mo_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_reema_ilo_receipt" model="ir.actions.act_window">
        <field name="name">ILO Receipts</field>
        <field name="res_model">reema.ilo.receipt</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_reema_ilo_receipt_search"/>
    </record>

    <!-- ═══════════════════════════════════════════════
         ILO PAYMENTS
    ═══════════════════════════════════════════════ -->

    <record id="view_reema_ilo_payment_form" model="ir.ui.view">
        <field name="name">reema.ilo.payment.form</field>
        <field name="model">reema.ilo.payment</field>
        <field name="arch" type="xml">
            <form string="ILO Payment">
                <header>
                    <button name="action_confirm" string="Confirm Payment" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Confirm this payment?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="contractor_id" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="payment_type" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <field name="notes" readonly="state != 'draft'" placeholder="Payment notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_reema_ilo_payment_list" model="ir.ui.view">
        <field name="name">reema.ilo.payment.list</field>
        <field name="model">reema.ilo.payment</field>
        <field name="arch" type="xml">
            <list string="ILO Payments">
                <field name="name"/>
                <field name="date"/>
                <field name="contractor_id"/>
                <field name="payment_type"/>
                <field name="amount" string="Amount (PKR)" sum="Total"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <record id="action_reema_ilo_payment" model="ir.actions.act_window">
        <field name="name">ILO Payments</field>
        <field name="res_model">reema.ilo.payment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══════════════════════════════════════════════
         MENUS
    ═══════════════════════════════════════════════ -->

    <menuitem id="menu_reema_ilo_root"
              name="ILO Management"
              parent="mrp.menu_mrp_root"
              sequence="35"/>

    <menuitem id="menu_reema_ilo_dispatch"
              name="Dispatches"
              parent="menu_reema_ilo_root"
              action="action_reema_ilo_dispatch"
              sequence="10"/>

    <menuitem id="menu_reema_ilo_pending"
              name="Pending"
              parent="menu_reema_ilo_root"
              action="action_reema_ilo_pending"
              sequence="20"/>

    <menuitem id="menu_reema_ilo_receipt"
              name="Receipts"
              parent="menu_reema_ilo_root"
              action="action_reema_ilo_receipt"
              sequence="30"/>

    <menuitem id="menu_reema_ilo_payment"
              name="Payments"
              parent="menu_reema_ilo_root"
              action="action_reema_ilo_payment"
              sequence="40"/>

    <menuitem id="menu_reema_ilo_piece_rate"
              name="ILO Piece Rates"
              parent="mrp.menu_mrp_configuration"
              action="action_reema_ilo_piece_rate"
              sequence="30"/>

</odoo>
