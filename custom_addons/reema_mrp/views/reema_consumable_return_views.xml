<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Window Action — returns only -->
    <record id="reema_consumable_return_action" model="ir.actions.act_window">
        <field name="name">Consumable Returns</field>
        <field name="res_model">reema.consumable.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('transaction_type', '=', 'return')]</field>
        <field name="context">{'default_transaction_type': 'return'}</field>
        <field name="view_ids" eval="[
            (0, 0, {'view_mode': 'list', 'view_id': ref('reema_mrp.reema_consumable_transaction_view_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('reema_mrp.reema_consumable_return_view_form')}),
        ]"/>
    </record>

    <!-- Menu under Store Issuances -->
    <menuitem id="reema_mrp_menu_consumable_returns_inventory"
              name="Consumable Returns"
              parent="reema_mrp_menu_issuances_root"
              action="reema_consumable_return_action"
              groups="base.group_user"
              sequence="3"/>

</odoo>
