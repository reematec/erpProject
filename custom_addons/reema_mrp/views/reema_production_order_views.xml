<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Production Order Form View -->
    <record id="reema_production_order_view_form" model="ir.ui.view">
        <field name="name">reema.production.order.form</field>
        <field name="model">reema.production.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_create_mos"
                            string="Create MOs"
                            type="object"
                            invisible="state != 'confirmed'"/>
                    <button name="action_done"
                            string="Mark Done"
                            type="object"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_mos"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-industry">
                            <field name="mo_count" widget="statinfo" string="MOs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Order Details">
                            <field name="invoice_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="partner_id" readonly="1"/>
                        </group>
                        <group string="Planning">
                            <field name="date_planned"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Production Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sample_id"
                                           options="{'no_create': True, 'no_edit': True}"/>
                                    <field name="product_tmpl_id" column_invisible="True"/>
                                    <field name="size"/>
                                    <field name="qty"/>
                                    <field name="bom_id"
                                           domain="[('product_tmpl_id', '=', product_tmpl_id)]"
                                           options="{'no_create': True}"/>
                                    <field name="mo_id" readonly="1"/>
                                    <button name="action_reset_mo"
                                            type="object"
                                            icon="fa-undo"
                                            title="Cancel and delete this MO so it can be recreated with the updated BOM"
                                            invisible="not mo_id"
                                            confirm="This will cancel and delete the linked Manufacturing Order. You can then click 'Create MOs' to recreate it with the updated BOM. Continue?"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Production Order List View -->
    <record id="reema_production_order_view_list" model="ir.ui.view">
        <field name="name">reema.production.order.list</field>
        <field name="model">reema.production.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="invoice_id"/>
                <field name="partner_id"/>
                <field name="date_planned"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'confirmed'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Window Action -->
    <record id="reema_production_order_action" model="ir.actions.act_window">
        <field name="name">Production Orders</field>
        <field name="res_model">reema.production.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu: Production Orders under the Production root menu -->
    <menuitem id="reema_mrp_menu_production_orders"
              name="Production Orders"
              parent="mrp.menu_mrp_root"
              action="reema_production_order_action"
              groups="base.group_user"
              sequence="5"/>

    <!-- Inherit Invoice Form: inject smart button + Create PO button -->
    <record id="reema_invoice_production_order_form" model="ir.ui.view">
        <field name="name">reema.invoice.production.order.form</field>
        <field name="model">reema.invoice</field>
        <field name="inherit_id" ref="reema_invoice.view_reema_invoice_form"/>
        <field name="arch" type="xml">
            <!-- Add Production Order smart button -->
            <xpath expr="//sheet" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_production_orders"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-industry">
                        <field name="production_order_count" widget="statinfo"
                               string="Production Orders"/>
                    </button>
                </div>
            </xpath>
            <!-- Add Create Production Order button in header -->
            <xpath expr="//header/button[@name='action_print_invoice']" position="before">
                <button name="action_create_production_order"
                        string="Create Production Order"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'accepted' or production_order_count > 0"/>
            </xpath>
        </field>
    </record>
</odoo>
