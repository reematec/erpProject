<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Rename top-level "Invoicing" to "Accounting" -->
    <record id="account.menu_finance" model="ir.ui.menu">
        <field name="name">Accounting</field>
    </record>

    <!-- ── Partner Reports ────────────────────────────────────────── -->
    <record id="account_financial_report.menu_aged_partner_balance_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="account.account_reports_partners_reports_menu"/>
        <field name="sequence">10</field>
    </record>
    <record id="account_financial_report.menu_open_items_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="account.account_reports_partners_reports_menu"/>
        <field name="sequence">20</field>
    </record>

    <!-- ── Statement Reports ──────────────────────────────────────── -->
    <record id="account_financial_report.menu_trial_balance_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="account.account_reports_legal_statements_menu"/>
        <field name="sequence">10</field>
    </record>
    <record id="account_financial_report.menu_general_ledger_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="account.account_reports_legal_statements_menu"/>
        <field name="sequence">20</field>
    </record>
    <record id="account_financial_report.menu_journal_ledger_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="account.account_reports_legal_statements_menu"/>
        <field name="sequence">30</field>
    </record>
    <record id="account_financial_report.menu_vat_report_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="account.account_reports_legal_statements_menu"/>
        <field name="sequence">40</field>
    </record>

    <!-- Hide the now-empty OCA grouping menu -->
    <record id="account_financial_report.menu_oca_reports" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- ── Community access fix ──────────────────────────────────────
         group_account_readonly is only activated by the Enterprise
         account_accountant module. In Community it is never assigned,
         so menus gated solely on it are invisible to everyone.
         We add group_account_manager (accounting admin) to each so
         that admins can reach them without needing Enterprise.
    ── -->
    <record id="account.menu_finance_entries" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('account.group_account_manager'))]"/>
    </record>
    <record id="account.menu_action_move_journal_line_form" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('account.group_account_manager'))]"/>
    </record>
    <record id="account.menu_action_account_moves_all" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('account.group_account_manager'))]"/>
    </record>
    <record id="account.menu_action_analytic_reporting" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('account.group_account_manager'))]"/>
    </record>
    <record id="account.menu_action_account_form" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('account.group_account_manager'))]"/>
    </record>
    <record id="account.account_report_folder" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('account.group_account_manager'))]"/>
    </record>
    <record id="account.menu_action_account_journal_group_list" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('account.group_account_manager'))]"/>
    </record>

</odoo>
